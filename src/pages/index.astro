---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CTF Platform">
    <main class="min-h-screen p-6 md:p-12">
        <header class="max-w-3xl mx-auto mb-12">
            <h1 class="text-4xl font-extrabold tracking-tight mb-2">CTF Platform</h1>
            <p class="text-base-content/60">Welcome to the challenge environment.</p>
        </header>

        <div id="user-info" class="hidden max-w-3xl mx-auto mb-8 flex justify-end items-center gap-4">
            <span class="text-sm">User: <span id="username-display" class="font-semibold text-primary"></span></span>
            <button onclick="logout()" class="btn btn-ghost btn-sm">Logout</button>
        </div>

        <div id="game-container" class="max-w-3xl mx-auto">
            <!-- Login Screen -->
            <section id="login-screen" class="card bg-base-100 border border-base-300 shadow-xl max-w-md mx-auto">
                <div class="card-body">
                    <h2 class="card-title text-2xl font-bold mb-2">Login</h2>
                    <p class="text-base-content/60 mb-6">Enter your username to start the challenge.</p>
                    <div class="form-control w-full gap-4">
                        <div class="form-control w-full">
                            <label class="label">
                                <span class="label-text font-medium">Username</span>
                            </label>
                            <input type="text" id="username-input" placeholder="e.g. player1" class="input input-bordered w-full focus:input-primary">
                        </div>
                        <button onclick="startSession()" class="btn btn-primary w-full mt-2">Start Session</button>
                    </div>
                </div>
            </section>

            <!-- Game UI -->
            <section id="game-ui" class="hidden">
                <div id="level-content" class="bg-base-200 p-8 rounded-xl shadow-sm"></div>
            </section>
        </div>
    </main>
</Layout>

<script>
    import "../scripts/main.js";
</script>
