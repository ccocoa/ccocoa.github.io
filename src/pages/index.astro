---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CTF Platform">
    <main class="min-h-screen p-4 md:p-8">
        <header class="border-b border-base-content/20 pb-6 mb-8 flex justify-between items-center">
            <h1 class="text-3xl font-bold tracking-tighter uppercase">Terminal_CTF</h1>
            <div id="user-info" class="hidden flex items-center gap-4">
                <span class="text-sm opacity-70">USER: <span id="username-display" class="font-bold text-primary"></span></span>
                <button onclick="logout()" class="btn btn-outline btn-xs btn-error">LOGOUT</button>
            </div>
        </header>

        <div id="game-container" class="max-w-4xl mx-auto">
            <!-- Login Screen -->
            <section id="login-screen" class="border border-base-content/20 p-8 bg-base-100">
                <h2 class="text-xl font-bold mb-6 uppercase">Authentication Required</h2>
                <div class="flex flex-col gap-4">
                    <input type="text" id="username-input" placeholder="ENTER_USERNAME" class="input input-bordered w-full rounded-none bg-base-200">
                    <button onclick="startSession()" class="btn btn-primary w-full rounded-none">INITIALIZE_SESSION</button>
                </div>
            </section>

            <!-- Game UI -->
            <section id="game-ui" class="hidden">
                <div id="level-content" class="p-6 border border-base-content/20 bg-base-100"></div>
            </section>
        </div>
    </main>
</Layout>

<script>
    import "../scripts/main.js";
</script>
