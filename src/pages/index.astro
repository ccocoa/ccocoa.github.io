---
---
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cocoa Learning Game - NeoBrutalism</title>
    <link rel="stylesheet" href="https://matifandy8.github.io/NeoBrutalismCSS/style.css">
    <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
    <header>
        <h1>Belajar Bareng Cocoa!</h1>
        <div id="user-info" style="display: none;">
            Halo, <span id="username-display"></span>! 
            <button onclick="logout()">Logout</button>
        </div>
    </header>

    <main id="game-container">
        <!-- Login Screen -->
        <section id="login-screen" class="card">
            <h2>Selamat Datang!</h2>
            <p>Masukkan nama kamu untuk memulai sesi belajar.</p>
            <input type="text" id="username-input" placeholder="Nama kamu...">
            <button onclick="startSession()">Mulai Belajar</button>
        </section>

        <!-- Game UI -->
        <section id="game-ui" style="display: none;">
            <div id="level-content"></div>
        </section>
    </main>

    <script src="/scripts/main.js" type="module"></script>
</body>
</html>
