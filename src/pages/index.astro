---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CTF Platform">
    <main class="min-h-screen p-6 md:p-12">
        <header class="max-w-3xl mx-auto mb-12 text-center">
            <pre class="overflow-x-auto whitespace-pre font-mono text-xs md:text-sm lg:text-base leading-none select-none">
{`   __________________   ____  __      __  ____                   
  / ____/_  __/ ____/  / __ \/ /___ _/ /_/ __/___  _________ ___ 
 / /     / / / /_     / /_/ / / __ `/ __/ /_/ __ \/ ___/ __ `__ \
/ /___  / / / __/    / ____/ / /_/ / /_/ __/ /_/ / /  / / / / / /
\____/ /_/ /_/      /_/   /_/\__,_/\__/_/  \____/_/  /_/ /_/ /_/ 
                                                                 `}
</pre>
        </header>

        <div id="user-info" class="hidden max-w-3xl mx-auto mb-8 flex justify-end items-center gap-4">
            <span class="text-sm">User: <span id="username-display" class="font-semibold text-primary"></span></span>
            <button onclick="logout()" class="btn btn-ghost btn-sm">Logout</button>
        </div>

        <div id="game-container" class="max-w-3xl mx-auto">
            <!-- Login Screen -->
            <section id="login-screen" class="max-w-md mx-auto">
                <h2 class="text-2xl font-bold mb-2">Login</h2>
                <p class="text-base-content/60 mb-6">Enter your username to start the challenge.</p>
                <div class="form-control w-full gap-4">
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-medium">Username</span>
                        </label>
                        <input type="text" id="username-input" placeholder="e.g. player1" class="input input-bordered w-full focus:input-primary h-12 px-4">
                    </div>
                    <button onclick="startSession()" class="btn btn-primary w-40 mt-2 h-12">Start Session</button>
                </div>
            </section>

            <!-- Game UI -->
            <section id="game-ui" class="hidden">
                <div id="level-content" class="bg-base-200 p-8 rounded-xl shadow-sm"></div>
            </section>
        </div>
    </main>
</Layout>

<script>
    import "../scripts/main.js";
</script>
